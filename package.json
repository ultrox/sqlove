{
  "name": "@ma.vu/sqlove",
  "version": "0.1.0",
  "description": "Type-safe SQL in TypeScript, powered by Effect",
  "type": "module",
  "bin": {
    "sqlove": "dist/cli.js"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sql",
    "postgres",
    "codegen",
    "type-safe",
    "effect"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "@vitest/coverage-v8": "^3.2.4",
    "effect": "^3.21.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "@effect/sql": ">=0.20.0",
    "@effect/sql-pg": ">=0.40.0",
    "effect": ">=3.0.0"
  }
}
