  paymentMethod: Schema.propertySignature(Schema.NullOr(Schema.String)).pipe(Schema.fromKey("payment_method")),
  paidAt: Schema.propertySignature(Schema.NullOr(Schema.DateFromString)).pipe(Schema.fromKey("paid_at")),
}) {}

/**
 * Full order details: user, items, products, payment.
 * @see \`/sql/order_details.sql\`
 */
export const orderDetails = (
  params: {
    readonly id: number;
  }
): Effect.Effect<ReadonlyArray<OrderDetailsRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<OrderDetailsRow>\`SELECT
  o.id AS order_id,
  o.status,
  u.name AS customer,
  p.name AS product,
  li.quantity,
  li.unit_price,
  (li.quantity * li.unit_price)::numeric(10,2) AS line_total,
  pay.method AS payment_method,
  pay.paid_at
FROM orders o
JOIN users u ON u.id = o.user_id
JOIN line_items li ON li.order_id = o.id
JOIN products p ON p.id = li.product_id
LEFT JOIN payments pay ON pay.order_id = o.id
WHERE o.id = \${params.id}\`
  ));

/** Rows returned by {@link productStats}.
 *  @see \`/sql/product_stats.sql\` */
export class ProductStatsRow extends Schema.Class<ProductStatsRow>("ProductStatsRow")({
