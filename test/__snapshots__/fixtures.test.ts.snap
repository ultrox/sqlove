exports[`fixtures > generated output matches snapshot 1`] = `
"// ============================================================
// Auto-generated by sqlove — do not edit.
// ============================================================

import { Effect } from "effect";
import * as Schema from "effect/Schema";
import type { SqlError } from "@effect/sql/SqlError";
import { SqlClient } from "@effect/sql/SqlClient";

// ---- Enums ----

/** Postgres enum \`order_status\` */
export const OrderStatus = Schema.Literal("pending", "confirmed", "shipped", "delivered", "cancelled");
export type OrderStatus = typeof OrderStatus.Type;

/** Postgres enum \`user_role\` */
export const UserRole = Schema.Literal("admin", "member", "guest");
export type UserRole = typeof UserRole.Type;

/** Rows returned by {@link aggregate}.
 *  @see \`/sql/aggregate.sql\` */
export class AggregateRow extends Schema.Class<AggregateRow>("AggregateRow")({
  total: Schema.Number,
  done: Schema.Number,
}) {}

/**
 * Aggregate query — expression columns, no table OID.
 * @see \`/sql/aggregate.sql\`
 */
export const aggregate: Effect.Effect<
  ReadonlyArray<AggregateRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<AggregateRow>\`SELECT
  count(*)::int AS total,
  count(*) FILTER (WHERE done)::int AS done
FROM todo\`
));

/** Rows returned by {@link arrayColumn}.
 *  @see \`/sql/array_column.sql\` */
export class ArrayColumnRow extends Schema.Class<ArrayColumnRow>("ArrayColumnRow")({
  id: Schema.Number,
  title: Schema.String,
  tags: Schema.Array(Schema.String),
}) {}

/**
 * Query returning array column.
 * @see \`/sql/array_column.sql\`
 */
export const arrayColumn: Effect.Effect<
  ReadonlyArray<ArrayColumnRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<ArrayColumnRow>\`SELECT id, title, tags FROM todo\`
));

/** Rows returned by {@link categoryTree}.
 *  @see \`/sql/category_tree.sql\` */
export class CategoryTreeRow extends Schema.Class<CategoryTreeRow>("CategoryTreeRow")({
  id: Schema.Number,
  name: Schema.String,
  depth: Schema.Number,
  parentId: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("parent_id")),
  productCount: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("product_count")),
}) {}

/**
 * Recursive category tree with product count.
 * @see \`/sql/category_tree.sql\`
 */
export const categoryTree: Effect.Effect<
  ReadonlyArray<CategoryTreeRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<CategoryTreeRow>\`WITH RECURSIVE cat_tree AS (
  SELECT id, name, parent_id, 0 AS depth
  FROM categories
  WHERE parent_id IS NULL

  UNION ALL

  SELECT c.id, c.name, c.parent_id, ct.depth + 1
  FROM categories c
  JOIN cat_tree ct ON ct.id = c.parent_id
)
SELECT
  ct.id,
  ct.name,
  ct.depth,
  ct.parent_id,
  count(p.id)::int AS product_count
FROM cat_tree ct
LEFT JOIN products p ON p.category_id = ct.id
GROUP BY ct.id, ct.name, ct.depth, ct.parent_id
ORDER BY ct.depth, ct.name\`
));

/** Rows returned by {@link cteRanked}.
 *  @see \`/sql/cte_ranked.sql\` */
export class CteRankedRow extends Schema.Class<CteRankedRow>("CteRankedRow")({
  name: Schema.String,
  email: Schema.String,
  totalSpent: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("total_spent")),
  rank: Schema.Number,
}) {}

/**
 * Users ranked by total spend using a CTE.
 * @see \`/sql/cte_ranked.sql\`
 */
export const cteRanked: Effect.Effect<
  ReadonlyArray<CteRankedRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<CteRankedRow>\`WITH user_spend AS (
  SELECT user_id, sum(total)::numeric(10,2) AS total_spent
  FROM orders
  WHERE status != 'cancelled'
  GROUP BY user_id
)
SELECT u.name, u.email, us.total_spent,
       rank() OVER (ORDER BY us.total_spent DESC)::int AS rank
FROM users u
JOIN user_spend us ON us.user_id = u.id\`
));

