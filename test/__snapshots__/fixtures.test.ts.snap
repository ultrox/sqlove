  sku: Schema.String,
  avgRating: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("avg_rating")),
  totalSold: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("total_sold")),
  revenue: Schema.String,
  reviewCount: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("review_count")),
}) {}

/**
 * Product stats: avg rating, total sold, revenue.
 * @see \`/sql/product_stats.sql\`
 */
export const productStats: Effect.Effect<
  ReadonlyArray<ProductStatsRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<ProductStatsRow>\`SELECT
  p.id,
  p.name,
  p.sku,
  coalesce(avg(r.rating), 0)::numeric(3,1) AS avg_rating,
  coalesce(sum(li.quantity), 0)::int AS total_sold,
  coalesce(sum(li.quantity * li.unit_price), 0)::numeric(10,2) AS revenue,
  count(DISTINCT r.id)::int AS review_count
FROM products p
LEFT JOIN line_items li ON li.product_id = p.id
LEFT JOIN reviews r ON r.product_id = p.id
GROUP BY p.id
ORDER BY revenue DESC\`
));

/** Rows returned by {@link refundReport}.
 *  @see \`/sql/refund_report.sql\` */
export class RefundReportRow extends Schema.Class<RefundReportRow>("RefundReportRow")({
  refundId: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("refund_id")),
  refundAmount: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("refund_amount")),
  reason: Schema.NullOr(Schema.String),
  refundedAt: Schema.propertySignature(Schema.DateFromString).pipe(Schema.fromKey("refunded_at")),
  orderId: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("order_id")),
  orderStatus: Schema.propertySignature(OrderStatus).pipe(Schema.fromKey("order_status")),
  customer: Schema.String,
  paymentMethod: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("payment_method")),
}) {}

/**
 * Refund report with order and payment details.
 * @see \`/sql/refund_report.sql\`
 */
export const refundReport = (
  params: {
    readonly refundedAt: Date;
    readonly refundedAt: Date;
  }
): Effect.Effect<ReadonlyArray<RefundReportRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<RefundReportRow>\`SELECT
  r.id AS refund_id,
  r.amount AS refund_amount,
  r.reason,
  r.refunded_at,
  o.id AS order_id,
  o.status AS order_status,
  u.name AS customer,
  p.method AS payment_method
FROM refunds r
JOIN payments p ON p.id = r.payment_id
JOIN orders o ON o.id = r.order_id
JOIN users u ON u.id = o.user_id
WHERE r.refunded_at >= \${params.refundedAt} AND r.refunded_at < \${params.refundedAt}
ORDER BY r.refunded_at DESC\`
  ));

/** Rows returned by {@link rightJoin}.
 *  @see \`/sql/right_join.sql\` */
export class RightJoinRow extends Schema.Class<RightJoinRow>("RightJoinRow")({
  name: Schema.NullOr(Schema.String),
  total: Schema.String,
}) {}

/**
 * Right join: left side columns become nullable.
 * @see \`/sql/right_join.sql\`
 */
export const rightJoin: Effect.Effect<
  ReadonlyArray<RightJoinRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<RightJoinRow>\`SELECT users.name, orders.total
FROM users
RIGHT JOIN orders ON orders.user_id = users.id\`
));

/** Rows returned by {@link searchProducts}.
 *  @see \`/sql/search_products.sql\` */
export class SearchProductsRow extends Schema.Class<SearchProductsRow>("SearchProductsRow")({
  id: Schema.Number,
  name: Schema.String,
  price: Schema.String,
  inStock: Schema.propertySignature(Schema.Boolean).pipe(Schema.fromKey("in_stock")),
  category: Schema.String,
  avgRating: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("avg_rating")),
}) {}

/**
 * Full text search on products with category and rating.
 * @see \`/sql/search_products.sql\`
 */
export const searchProducts = (
  params: {
    readonly name: string;
    readonly id: number;
  }
): Effect.Effect<ReadonlyArray<SearchProductsRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<SearchProductsRow>\`SELECT
  p.id,
  p.name,
  p.price,
  p.in_stock,
  c.name AS category,
  coalesce(avg(r.rating), 0)::numeric(3,1) AS avg_rating
FROM products p
LEFT JOIN categories c ON c.id = p.category_id
LEFT JOIN reviews r ON r.product_id = p.id
WHERE p.name ILIKE \${params.name}
  AND (\${params.id}::int IS NULL OR c.id = \${params.id})
GROUP BY p.id, c.name
ORDER BY p.name\`
  ));

/** Rows returned by {@link simpleSelect}.
 *  @see \`/sql/simple_select.sql\` */
export class SimpleSelectRow extends Schema.Class<SimpleSelectRow>("SimpleSelectRow")({
  id: Schema.Number,
  name: Schema.String,
  email: Schema.String,
}) {}

/**
 * Simple select, no params.
 * @see \`/sql/simple_select.sql\`
 */
export const simpleSelect: Effect.Effect<
  ReadonlyArray<SimpleSelectRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<SimpleSelectRow>\`SELECT id, name, email FROM users ORDER BY name\`
));

/** Rows returned by {@link upsertReview}.
 *  @see \`/sql/upsert_review.sql\` */
export class UpsertReviewRow extends Schema.Class<UpsertReviewRow>("UpsertReviewRow")({
  id: Schema.Number,
  rating: Schema.Number,
  createdAt: Schema.propertySignature(Schema.DateFromString).pipe(Schema.fromKey("created_at")),
}) {}

/**
 * Upsert a review — insert or update on conflict.
 * @see \`/sql/upsert_review.sql\`
 */
export const upsertReview = (
  params: {
    readonly userId: number;
    readonly productId: number;
    readonly rating: number;
    readonly body: string | null;
  }
): Effect.Effect<ReadonlyArray<UpsertReviewRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<UpsertReviewRow>\`INSERT INTO reviews (user_id, product_id, rating, body)
VALUES (\${params.userId}, \${params.productId}, \${params.rating}, \${params.body})
ON CONFLICT (user_id, product_id)
DO UPDATE SET rating = \${params.rating}, body = \${params.body}
RETURNING id, rating, created_at\`
  ));

/** Rows returned by {@link userDashboard}.
 *  @see \`/sql/user_dashboard.sql\` */
export class UserDashboardRow extends Schema.Class<UserDashboardRow>("UserDashboardRow")({
  id: Schema.Number,
  name: Schema.String,
  email: Schema.String,
  role: UserRole,
  tags: Schema.Array(Schema.String),
  orderCount: Schema.propertySignature(Schema.Number).pipe(Schema.fromKey("order_count")),
  totalSpent: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("total_spent")),
  lastOrderAt: Schema.propertySignature(Schema.DateFromString).pipe(Schema.fromKey("last_order_at")),
}) {}

/**
 * User dashboard: profile, order count, total spent, latest order.
 * @see \`/sql/user_dashboard.sql\`
 */
export const userDashboard = (
  params: {
    readonly id: number;
  }
): Effect.Effect<ReadonlyArray<UserDashboardRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<UserDashboardRow>\`SELECT
  u.id,
  u.name,
  u.email,
  u.role,
  u.tags,
  count(o.id)::int AS order_count,
  coalesce(sum(o.total), 0)::numeric(10,2) AS total_spent,
  max(o.created_at) AS last_order_at
FROM users u
LEFT JOIN orders o ON o.user_id = u.id AND o.status != 'cancelled'
WHERE u.id = \${params.id}
GROUP BY u.id\`
  ));

/** Rows returned by {@link windowRunningTotal}.
 *  @see \`/sql/window_running_total.sql\` */
export class WindowRunningTotalRow extends Schema.Class<WindowRunningTotalRow>("WindowRunningTotalRow")({
  id: Schema.Number,
  name: Schema.String,
  total: Schema.String,
  createdAt: Schema.propertySignature(Schema.DateFromString).pipe(Schema.fromKey("created_at")),
  runningTotal: Schema.propertySignature(Schema.String).pipe(Schema.fromKey("running_total")),
}) {}

/**
 * Running total of orders per user using window function.
 * @see \`/sql/window_running_total.sql\`
 */
export const windowRunningTotal: Effect.Effect<
  ReadonlyArray<WindowRunningTotalRow>,
  SqlError,
  SqlClient
> = SqlClient.pipe(Effect.flatMap((sql) =>
  sql<WindowRunningTotalRow>\`SELECT
  o.id,
  u.name,
  o.total,
  o.created_at,
  sum(o.total) OVER (
    PARTITION BY o.user_id
    ORDER BY o.created_at
  )::numeric(10,2) AS running_total
FROM orders o
JOIN users u ON u.id = o.user_id
WHERE o.status != 'cancelled'
ORDER BY u.name, o.created_at\`
));

/** Rows returned by {@link withParams}.
 *  @see \`/sql/with_params.sql\` */
export class WithParamsRow extends Schema.Class<WithParamsRow>("WithParamsRow")({
  id: Schema.Number,
  name: Schema.String,
  email: Schema.String,
}) {}

/**
 * Find user by email and minimum age.
 * @see \`/sql/with_params.sql\`
 */
export const withParams = (
  params: {
    readonly email: string;
    readonly age: number;
  }
): Effect.Effect<ReadonlyArray<WithParamsRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<WithParamsRow>\`SELECT id, name, email
FROM users
WHERE email = \${params.email} AND age >= \${params.age}\`
  ));
"
`;
