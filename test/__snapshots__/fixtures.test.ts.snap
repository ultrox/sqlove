}) {}

/**
 * Query using multiple enum types.
 * @see \`/sql/multi_enum.sql\`
 */
export const multiEnum = (
  params: {
    readonly role: UserRole;
    readonly status: OrderStatus;
  }
): Effect.Effect<ReadonlyArray<MultiEnumRow>, SqlError, SqlClient> =>
  SqlClient.pipe(Effect.flatMap((sql) =>
    sql<MultiEnumRow>\`SELECT
  u.name,
  u.role,
  o.id AS order_id,
  o.status
FROM users u
JOIN orders o ON o.user_id = u.id
WHERE u.role = \${params.role}::user_role
  AND o.status = \${params.status}::order_status\`
  ));

